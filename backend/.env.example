# ---- Server ----
PORT=5000
NODE_ENV=development

# Comma-separated list of allowed frontend origins (CORS)
CLIENT_URL=http://localhost:5173

# ---- Database ----
# Local:  mongodb://127.0.0.1:27017/diamond_inventory
# Atlas:  mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/diamond_inventory
MONGO_URI=mongodb://127.0.0.1:27017/diamond_inventory

# ---- Auth ----
JWT_SECRET=change_me_to_a_long_random_string
JWT_EXPIRES_IN=7d

# ---- Seed admin (used by `npm run seed`) ----
ADMIN_NAME=Admin
ADMIN_EMAIL=admin@stienhardt.com
ADMIN_PASSWORD=Admin@12345

# ---- Cloudinary (image / certificate uploads) ----
# Leave blank to disable uploads (app still runs; image fields stay empty)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
